---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Tracking global AI adoption with the AI Matrix framework' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title === 'Home' ? 'AI Matrix Live' : `${title} — AI Matrix Live`}</title>
  </head>
  <body>
    <nav class="nav">
      <div class="nav__inner container">
        <a href="/" class="nav__logo">
          <span class="nav__logo-text">AI Matrix</span>
          <span class="nav__logo-badge">Live</span>
        </a>
        <ul class="nav__links">
          <li><a href="/" class:list={[{ active: currentPath === '/' }]}>Home</a></li>
          <li><a href="/explore" class:list={[{ active: currentPath === '/explore' || currentPath === '/explore/' }]}>Explore</a></li>
          <li><a href="/framework" class:list={[{ active: currentPath === '/framework' || currentPath === '/framework/' }]}>Framework</a></li>
          <li><a href="/methodology" class:list={[{ active: currentPath === '/methodology' || currentPath === '/methodology/' }]}>Methodology</a></li>
          <li><a href="/updates" class:list={[{ active: currentPath === '/updates' || currentPath === '/updates/' }]}>Updates</a></li>
        </ul>
      </div>
    </nav>

    <canvas id="globe-bg" aria-hidden="true"></canvas>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer__inner container">
        <p class="footer__authors">
          By <a href="https://ewansimpson.org/" target="_blank" rel="noopener">Ewan Simpson</a>
          and <a href="https://msquinn.com" target="_blank" rel="noopener">Michael Quinn</a>
        </p>
        <p>
          Data: <a href="https://huggingface.co/datasets/Anthropic/EconomicIndex" target="_blank" rel="noopener">Anthropic Economic Index</a>
          &middot;
          Paper: <a href="https://doi.org/10.5281/zenodo.18181372" target="_blank" rel="noopener">Simpson (2026)</a>
          &middot;
          Code: <a href="https://github.com/michaelquinn32/ai-matrix-live" target="_blank" rel="noopener">GitHub</a>
        </p>
      </div>
    </footer>

    <style>
      .nav {
        position: sticky;
        top: 0;
        z-index: 100;
        background: var(--bg);
        border-bottom: 1px solid var(--border);
        backdrop-filter: blur(12px);
      }

      .nav__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 56px;
      }

      .nav__logo {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: var(--font-display);
        font-size: var(--text-h3);
        color: var(--text-primary);
        text-decoration: none;
      }

      .nav__logo-badge {
        font-family: var(--font-mono);
        font-size: var(--text-small);
        color: var(--accent);
        border: 1px solid var(--accent);
        border-radius: 4px;
        padding: 1px 6px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .nav__links {
        display: flex;
        list-style: none;
        gap: var(--space-md);
      }

      .nav__links a {
        font-family: var(--font-body);
        font-size: var(--text-small);
        font-weight: 500;
        color: var(--text-secondary);
        text-decoration: none;
        padding: 4px 0;
        border-bottom: 2px solid transparent;
        transition: color var(--transition-fast), border-color var(--transition-fast);
      }

      .nav__links a:hover {
        color: var(--text-primary);
        opacity: 1;
      }

      .nav__links a.active {
        color: var(--text-primary);
        border-bottom-color: var(--accent);
      }

      .footer {
        margin-top: var(--space-lg);
        padding: var(--space-sm) 0;
        border-top: 1px solid var(--border);
        background: var(--bg);
        position: relative;
        z-index: 1;
      }

      .footer__inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
      }

      .footer p {
        font-size: var(--text-mono);
        color: var(--text-muted);
        text-align: center;
        margin: 0;
      }

      .footer__authors {
        color: var(--text-secondary);
      }

      .footer a {
        color: var(--text-secondary);
      }

      @media (max-width: 600px) {
        .nav__links {
          gap: var(--space-sm);
        }

        .nav__links a {
          font-size: var(--text-mono);
        }
      }
      #globe-bg {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        pointer-events: none;
        z-index: -1;
      }
    </style>

    <script is:inline>
    (function() {
      var canvas = document.getElementById('globe-bg');
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      var dpr = window.devicePixelRatio || 1;
      var landRings = null;

      // Load land outlines
      fetch('/land.json').then(function(r) { return r.json(); }).then(function(data) {
        landRings = data;
        draw();
      });

      function resize() {
        canvas.width = window.innerWidth * dpr;
        canvas.height = window.innerHeight * dpr;
        canvas.style.width = window.innerWidth + 'px';
        canvas.style.height = window.innerHeight + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        draw();
      }

      function draw() {
        var w = window.innerWidth;
        var h = window.innerHeight;
        ctx.clearRect(0, 0, w, h);

        // Globe sits in bottom third, center cut off by viewport bottom
        // Radius is large so it dominates the lower portion
        var r = Math.max(w, h) * 0.6;
        var cx = w * 0.5;
        var cy = h + r * 0.35;  // push center below viewport so top ~65% of globe shows

        // Rotation: tilt to show Europe/Africa/Asia facing
        var rotLon = -10 * Math.PI / 180;
        var rotLat = 20 * Math.PI / 180;

        // Clip to globe circle
        ctx.save();
        ctx.beginPath();
        ctx.arc(cx, cy, r, 0, Math.PI * 2);
        ctx.clip();

        // Graticule: longitude lines every 10 degrees
        ctx.strokeStyle = 'rgba(235, 230, 220, 0.045)';
        ctx.lineWidth = 0.5;
        for (var lon = -180; lon < 180; lon += 10) {
          ctx.beginPath();
          var first = true;
          for (var lat = -90; lat <= 90; lat += 2) {
            var p = project(lat, lon, rotLat, rotLon, cx, cy, r);
            if (p) {
              if (first) { ctx.moveTo(p[0], p[1]); first = false; }
              else ctx.lineTo(p[0], p[1]);
            } else { first = true; }
          }
          ctx.stroke();
        }

        // Graticule: latitude lines every 10 degrees
        for (var lat2 = -80; lat2 <= 80; lat2 += 10) {
          ctx.beginPath();
          var first2 = true;
          for (var lon2 = -180; lon2 <= 180; lon2 += 2) {
            var p2 = project(lat2, lon2, rotLat, rotLon, cx, cy, r);
            if (p2) {
              if (first2) { ctx.moveTo(p2[0], p2[1]); first2 = false; }
              else ctx.lineTo(p2[0], p2[1]);
            } else { first2 = true; }
          }
          ctx.stroke();
        }

        // Land outlines
        if (landRings) {
          ctx.strokeStyle = 'rgba(235, 230, 220, 0.07)';
          ctx.lineWidth = 0.5;
          for (var i = 0; i < landRings.length; i++) {
            var ring = landRings[i];
            ctx.beginPath();
            var firstPt = true;
            for (var j = 0; j < ring.length; j++) {
              var pt = project(ring[j][1], ring[j][0], rotLat, rotLon, cx, cy, r);
              if (pt) {
                if (firstPt) { ctx.moveTo(pt[0], pt[1]); firstPt = false; }
                else ctx.lineTo(pt[0], pt[1]);
              } else { firstPt = true; }
            }
            ctx.stroke();
          }
        }

        // Globe outline (subtle)
        ctx.beginPath();
        ctx.arc(cx, cy, r, 0, Math.PI * 2);
        ctx.strokeStyle = 'rgba(235, 230, 220, 0.06)';
        ctx.lineWidth = 1;
        ctx.stroke();

        ctx.restore();
      }

      // Orthographic projection
      function project(lat, lon, rotLat, rotLon, cx, cy, radius) {
        var lam = lon * Math.PI / 180 + rotLon;
        var phi = lat * Math.PI / 180;
        var cosPhi = Math.cos(phi);
        var x = cosPhi * Math.sin(lam);
        var y = Math.sin(phi) * Math.cos(rotLat) - cosPhi * Math.cos(lam) * Math.sin(rotLat);
        var z = Math.sin(phi) * Math.sin(rotLat) + cosPhi * Math.cos(lam) * Math.cos(rotLat);
        if (z < 0) return null;
        return [cx + x * radius, cy - y * radius];
      }

      window.addEventListener('resize', resize);
      resize();
    })();
    </script>
  </body>
</html>
