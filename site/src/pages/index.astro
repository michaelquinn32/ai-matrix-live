---
import Base from '../layouts/Base.astro';
---

<Base title="Dashboard">
  <section class="hero">
    <div class="container">
      <div class="hero__header">
        <h1>Global AI Adoption</h1>
        <p class="hero__subtitle">
          Where countries stand on access and agency, updated with each
          Anthropic Economic Index release.
        </p>
      </div>
      <div class="chart-container">
        <div id="matrix-scatter"></div>
      </div>
      <p class="hero__updated" id="last-updated"></p>
    </div>
  </section>

  <section class="container" style="margin-top: var(--space-lg);">
    <div class="prose">
      <h2>What you're looking at</h2>
      <p>
        Each dot is a country. The horizontal axis measures <strong>access</strong>:
        how many people per capita are using Claude. The vertical axis measures
        <strong>agency</strong>: whether those people co-create with AI or just
        issue commands. Bigger dots mean more total conversations.
      </p>
      <p>
        Press play to watch countries shift between releases. The four colors
        map to the AI Matrix quadrants.
        <a href="/framework">Learn about the framework &rarr;</a>
      </p>
    </div>
  </section>
</Base>

<script is:inline src="https://cdn.plot.ly/plotly-2.35.3.min.js"></script>
<script is:inline>
(async function () {
  // -----------------------------------------------------------------------
  // Config
  // -----------------------------------------------------------------------

  // Region colors — designed for dark background, high contrast between groups
  const REGION_COLORS = {
    'East Asia & Pacific':       '#36b5d8',
    'Europe & Central Asia':     '#a78bfa',
    'Latin America & Caribbean': '#34d399',
    'Middle East & North Africa':'#fbbf24',
    'North America':             '#f87171',
    'South Asia':                '#fb923c',
    'Sub-Saharan Africa':        '#60a5fa',
  };

  // Normalize region names (World Bank API has trailing spaces and long names)
  function normalizeRegion(r) {
    if (!r) return 'Other';
    r = r.trim();
    if (r.indexOf('Middle East') === 0) return 'Middle East & North Africa';
    if (r.indexOf('Latin America') === 0) return 'Latin America & Caribbean';
    if (r.indexOf('Sub-Saharan') === 0) return 'Sub-Saharan Africa';
    return r;
  }

  const REGION_ORDER = Object.keys(REGION_COLORS);

  const RELEASE_LABELS = {
    '2025_09_15': 'Sep 2025',
    '2026_01_15': 'Jan 2026',
    '2026_03_24': 'Mar 2026',
  };

  // -----------------------------------------------------------------------
  // Load data
  // -----------------------------------------------------------------------

  const resp = await fetch('/data/waves.json');
  const waves = await resp.json();

  if (!waves || waves.length === 0) {
    document.getElementById('matrix-scatter').innerHTML =
      '<p style="text-align:center;color:var(--text-muted)">No data available</p>';
    return;
  }

  // Build a union of all countries across all waves (for consistent animation)
  const allIso3 = new Set();
  for (const wave of waves) {
    for (const c of wave.countries) {
      allIso3.add(c.iso3);
    }
  }
  const countryList = Array.from(allIso3).sort();

  // -----------------------------------------------------------------------
  // Build frames
  // -----------------------------------------------------------------------

  // Dot size from population (log-scaled, Gapminder style)
  function dotSize(population) {
    if (!population || population <= 0) return 8;
    var s = Math.log10(population);
    // log10(500K)=5.7, log10(1.4B)=9.15 -> map to 8-50px range
    return Math.max(8, Math.min(50, (s - 5) * 10));
  }

  // Compute per-wave medians
  function waveMedians(wave) {
    var xs = [], ys = [];
    for (var i = 0; i < wave.countries.length; i++) {
      var c = wave.countries[i];
      if (c.access_score != null && c.agency_composite != null) {
        xs.push(c.access_score);
        ys.push(c.agency_composite);
      }
    }
    xs.sort(function(a,b){return a-b;});
    ys.sort(function(a,b){return a-b;});
    return {
      x: xs[Math.floor(xs.length/2)],
      y: ys[Math.floor(ys.length/2)]
    };
  }

  // Derive quadrant label from position relative to wave-specific medians
  function quadrantLabel(access, agency, medX, medY) {
    var highAccess = access >= medX;
    var highAgency = agency >= medY;
    if (highAccess && highAgency) return 'Full Empowerment';
    if (!highAccess && highAgency) return 'Elite Empowerment';
    if (highAccess && !highAgency) return 'Passive Dependency';
    return 'Full Dependency';
  }

  function buildTraces(wave) {
    var wMed = waveMedians(wave);
    // Group countries by region for legend coloring
    var byRegion = {};
    for (var i = 0; i < REGION_ORDER.length; i++) {
      byRegion[REGION_ORDER[i]] = [];
    }

    for (var j = 0; j < wave.countries.length; j++) {
      var c = wave.countries[j];
      if (c.access_score == null || c.agency_composite == null) continue;
      var region = normalizeRegion(c.region);
      if (!byRegion[region]) byRegion[region] = [];
      byRegion[region].push(c);
    }

    return REGION_ORDER.map(function (region) {
      var countries = byRegion[region] || [];
      return {
        x: countries.map(function (c) { return c.access_score; }),
        y: countries.map(function (c) { return c.agency_composite; }),
        text: countries.map(function (c) { return c.country_name; }),
        customdata: countries.map(function (c) {
          var pop = c.population || 0;
          var popLabel = pop >= 1e9 ? (pop/1e9).toFixed(1) + 'B'
                       : pop >= 1e6 ? (pop/1e6).toFixed(1) + 'M'
                       : pop >= 1e3 ? (pop/1e3).toFixed(0) + 'K'
                       : pop.toFixed(0);
          var perCapita = pop > 0 ? (c.usage_count / pop * 1000000) : 0;
          return [
            c.iso3,
            normalizeRegion(c.region),
            popLabel,
            perCapita.toFixed(0),
            c.usage_count,
            (c.co_creation != null ? (c.co_creation * 100).toFixed(0) + '%' : ''),
            (c.task_success_rate != null ? (c.task_success_rate * 100).toFixed(0) + '%' : ''),
          ];
        }),
        marker: {
          size: countries.map(function (c) { return dotSize(c.population); }),
          color: REGION_COLORS[region] || '#888',
          opacity: 0.85,
          line: { width: 1, color: 'rgba(255,255,255,0.15)' },
        },
        name: region,
        type: 'scatter',
        mode: 'markers',
        hovertemplate:
          '<b>%{text}</b><br>' +
          '%{customdata[1]}  Pop: %{customdata[2]}<br>' +
          '%{customdata[3]} conversations per 1M people<br>' +
          '%{customdata[4]:,.0f} total conversations' +
          '<extra></extra>',
      };
    });
  }

  // Initial data: first wave
  var initialTraces = buildTraces(waves[0]);

  // Frames for animation
  var frames = waves.map(function (wave) {
    var label = RELEASE_LABELS[wave.release] || wave.release;
    var traces = buildTraces(wave);
    return {
      name: label,
      data: traces,
    };
  });

  // -----------------------------------------------------------------------
  // Layout
  // -----------------------------------------------------------------------

  // Compute axis ranges from all waves
  var allX = [], allY = [];
  for (var w = 0; w < waves.length; w++) {
    for (var c = 0; c < waves[w].countries.length; c++) {
      var country = waves[w].countries[c];
      if (country.access_score != null) allX.push(country.access_score);
      if (country.agency_composite != null) allY.push(country.agency_composite);
    }
  }
  var xMin = Math.min.apply(null, allX), xMax = Math.max.apply(null, allX);
  var yMin = Math.min.apply(null, allY), yMax = Math.max.apply(null, allY);

  // Medians for quadrant crosshairs (from latest wave)
  var latestCountries = waves[waves.length - 1].countries.filter(function (c) {
    return c.access_score != null && c.agency_composite != null;
  });
  var sortedX = latestCountries.map(function (c) { return c.access_score; }).sort(function (a, b) { return a - b; });
  var sortedY = latestCountries.map(function (c) { return c.agency_composite; }).sort(function (a, b) { return a - b; });
  var medianX = sortedX[Math.floor(sortedX.length / 2)];
  var medianY = sortedY[Math.floor(sortedY.length / 2)];

  // Symmetric ranges around the median so the crosshairs sit at the visual center
  var xSpread = Math.max(xMax - medianX, medianX - xMin) * 1.15;
  var ySpread = Math.max(yMax - medianY, medianY - yMin) * 1.15;
  var xRangeMin = medianX - xSpread;
  var xRangeMax = medianX + xSpread;
  var yRangeMin = medianY - ySpread;
  var yRangeMax = medianY + ySpread;

  var sliderSteps = waves.map(function (wave, i) {
    var label = RELEASE_LABELS[wave.release] || wave.release;
    return {
      method: 'animate',
      label: label,
      args: [
        [label],
        {
          mode: 'immediate',
          transition: { duration: 800, easing: 'cubic-in-out' },
          frame: { duration: 800, redraw: false },
        },
      ],
    };
  });

  var layout = {
    xaxis: {
      title: { text: 'Access to AI Resources →', font: { family: 'Instrument Sans, system-ui, sans-serif', size: 13, color: 'rgba(235,230,220,0.5)' }, standoff: 15 },
      range: [xRangeMin, xRangeMax],
      showgrid: false,
      showticklabels: false,
      zeroline: false,
      fixedrange: true,
    },
    yaxis: {
      title: { text: 'Human Agency →', font: { family: 'Instrument Sans, system-ui, sans-serif', size: 13, color: 'rgba(235,230,220,0.5)' }, standoff: 15 },
      range: [yRangeMin, yRangeMax],
      showgrid: false,
      showticklabels: false,
      zeroline: false,
      fixedrange: true,
    },
    shapes: [
      // Quadrant background rectangles (matching the paper's Figure 1)
      // Top-right: Full Empowerment (green tint)
      { type: 'rect', x0: medianX, x1: xRangeMax, y0: medianY, y1: yRangeMax,
        fillcolor: 'rgba(52,211,153,0.04)', line: { width: 0 }, layer: 'below' },
      // Top-left: Elite Empowerment (amber tint)
      { type: 'rect', x0: xRangeMin, x1: medianX, y0: medianY, y1: yRangeMax,
        fillcolor: 'rgba(251,191,36,0.04)', line: { width: 0 }, layer: 'below' },
      // Bottom-right: Passive Dependency (cool blue tint)
      { type: 'rect', x0: medianX, x1: xRangeMax, y0: yRangeMin, y1: medianY,
        fillcolor: 'rgba(96,165,250,0.04)', line: { width: 0 }, layer: 'below' },
      // Bottom-left: Full Dependency (red tint)
      { type: 'rect', x0: xRangeMin, x1: medianX, y0: yRangeMin, y1: medianY,
        fillcolor: 'rgba(248,113,113,0.05)', line: { width: 0 }, layer: 'below' },
      // Crosshair lines at median
      { type: 'line', x0: medianX, x1: medianX, y0: yRangeMin, y1: yRangeMax,
        line: { color: 'rgba(235,230,220,0.15)', width: 1 } },
      { type: 'line', x0: xRangeMin, x1: xRangeMax, y0: medianY, y1: medianY,
        line: { color: 'rgba(235,230,220,0.15)', width: 1 } },
    ],
    annotations: [
      // Quadrant labels centered in each quadrant
      { x: xRangeMax, y: yRangeMax,
        text: '1. Full Empowerment', showarrow: false,
        font: { family: 'Instrument Serif, serif', size: 13, color: 'rgba(52,211,153,0.35)' },
        xanchor: 'right', yanchor: 'top', xshift: -8, yshift: -8 },
      { x: xRangeMin, y: yRangeMax,
        text: '2. Elite Empowerment', showarrow: false,
        font: { family: 'Instrument Serif, serif', size: 13, color: 'rgba(251,191,36,0.35)' },
        xanchor: 'left', yanchor: 'top', xshift: 8, yshift: -8 },
      { x: xRangeMax, y: yRangeMin,
        text: '3. Passive Dependency', showarrow: false,
        font: { family: 'Instrument Serif, serif', size: 13, color: 'rgba(96,165,250,0.35)' },
        xanchor: 'right', yanchor: 'bottom', xshift: -8, yshift: 8 },
      { x: xRangeMin, y: yRangeMin,
        text: '4. Full Dependency', showarrow: false,
        font: { family: 'Instrument Serif, serif', size: 13, color: 'rgba(248,113,113,0.35)' },
        xanchor: 'left', yanchor: 'bottom', xshift: 8, yshift: 8 },
    ],
    plot_bgcolor: '#0f1014',
    paper_bgcolor: '#0f1014',
    font: { color: 'rgba(235,230,220,0.85)', family: 'Instrument Sans, system-ui, sans-serif' },
    hoverlabel: {
      font: { family: 'JetBrains Mono, monospace', size: 12, color: '#f0ede6' },
      bgcolor: 'rgba(10,10,14,0.95)',
      bordercolor: 'rgba(235,230,220,0.3)',
      align: 'left',
    },
    legend: {
      orientation: 'h',
      yanchor: 'bottom',
      y: 1.02,
      xanchor: 'center',
      x: 0.5,
      font: { size: 12, family: 'JetBrains Mono, monospace' },
    },
    margin: { l: 40, r: 40, t: 40, b: 80 },
    hovermode: 'closest',

    // Animation controls
    updatemenus: [{
      type: 'buttons',
      showactive: false,
      x: 0,
      y: -0.12,
      xanchor: 'left',
      yanchor: 'top',
      direction: 'left',
      pad: { t: 0, r: 10 },
      font: { family: 'JetBrains Mono, monospace', size: 11, color: 'rgba(235,230,220,0.85)' },
      buttons: [
        {
          label: '&#9654; Play',
          method: 'animate',
          args: [
            null,
            {
              fromcurrent: true,
              frame: { duration: 1500, redraw: false },
              transition: { duration: 800, easing: 'cubic-in-out' },
              mode: 'immediate',
            },
          ],
        },
        {
          label: '&#9724; Pause',
          method: 'animate',
          args: [
            [null],
            {
              mode: 'immediate',
              frame: { duration: 0, redraw: false },
              transition: { duration: 0 },
            },
          ],
        },
      ],
    }],

    sliders: [{
      active: 0,
      pad: { t: 30, b: 10 },
      x: 0,
      len: 1.0,
      xanchor: 'left',
      y: -0.12,
      yanchor: 'top',
      currentvalue: {
        prefix: 'Release: ',
        visible: true,
        xanchor: 'center',
        font: { family: 'JetBrains Mono, monospace', size: 12, color: 'rgba(235,230,220,0.85)' },
      },
      transition: { duration: 800, easing: 'cubic-in-out' },
      steps: sliderSteps,
    }],
  };

  // -----------------------------------------------------------------------
  // Render
  // -----------------------------------------------------------------------

  var config = {
    responsive: true,
    displayModeBar: false,
    staticPlot: false,
    scrollZoom: false,
  };

  Plotly.newPlot('matrix-scatter', initialTraces, layout, config).then(function () {
    Plotly.addFrames('matrix-scatter', frames);
  });

  // Update the "last updated" text
  var latest = waves[waves.length - 1];
  var dateEnd = latest.metadata && latest.metadata.date_end;
  var el = document.getElementById('last-updated');
  if (el && dateEnd) {
    var releaseLabel = RELEASE_LABELS[latest.release] || latest.release;
    el.textContent = 'Last updated: ' + releaseLabel + ' release (' + dateEnd + ')';
  }
})();
</script>

<style>
  .hero {
    padding: var(--space-lg) 0 var(--space-md);
  }

  .hero__header {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .hero__subtitle {
    font-size: var(--text-h3);
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .hero__updated {
    text-align: center;
    font-family: var(--font-mono);
    font-size: var(--text-small);
    color: var(--text-muted);
    margin-top: var(--space-sm);
  }

  #matrix-scatter {
    width: 100%;
    min-height: 550px;
  }

  @media (max-width: 600px) {
    #matrix-scatter {
      min-height: 400px;
    }
  }
</style>
